---
import { Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'

const headings = [
  { depth: 2, slug: 'about-me', text: 'About Me' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment>
  <p>Developer / Student</p>
  <p>
    Nothing is impossible.
    <Spoiler>Stay curious, stay hungry.</Spoiler>
  </p>

  <h2 id='about-me'>About Me</h2>
  <ul>
    <li>CS student, interested in operating systems, computer architecture, and programming languages</li>
    <li>Learning and sharing knowledge through this blog</li>
    <li>Interests: C++, RISC-V, Linux, xv6, discrete math</li>
  </ul>

  <h2 id='about-blog'>About Blog</h2>
  <p>Website history:</p>
  <Timeline
    events={[
      {
        date: '2026-05-18',
        content:
          'Migrated to <a href="https://github.com/cworld1/astro-theme-pure" target="_blank">Astro Theme Pure</a> with newsprint-inspired design'
      },
      {
        date: '2025-07-27',
        content:
          'Started writing xv6-riscv book notes'
      },
      {
        date: '2025-05-15',
        content:
          'Began publishing CS110 and CS106L course notes'
      }
    ]}
  />
  <p>
    This blog is built with the following technologies:
  </p>
  <ul>
    <li>Framework: <a href='https://astro.build/' target='_blank'>Astro</a></li>
    <li>Theme: <a href='https://github.com/cworld1/astro-theme-pure' target='_blank'>Astro Theme Pure</a></li>
    <li>Hosting: <a href='https://pages.github.com/' target='_blank'>GitHub Pages</a></li>
    <li>Search: <a href='https://pagefind.app/' target='_blank'>Pagefind</a></li>
    <li>Typography: <a href='https://fonts.google.com/specimen/PT+Serif' target='_blank'>PT Serif</a> (newsprint style)</li>
  </ul>
</PageLayout>
