---
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  { depth: 2, slug: 'course-notes', text: 'Course Notes' },
  { depth: 2, slug: 'projects', text: 'Projects' }
]
---

<PageLayout title='Projects' {headings} view>
  <p>Course notes and projects I'm working on.</p>

  <h2 id='course-notes'>Course Notes</h2>
  <ProjectSection
    projects={[
      {
        name: 'CS110 - Principles of Computer Systems',
        description: 'Stanford CS110 course notes, including lecture notes and slides (Chinese translation)',
        links: [
          { type: 'site', href: '/blog/lecture-notes-zh/lec01/' }
        ]
      },
      {
        name: 'CS106L - Standard C++ Programming',
        description: 'Stanford CS106L course notes on modern C++ features (Chinese translation)',
        links: [
          { type: 'site', href: '/blog/translated_markdown/01-Welcome/' }
        ]
      },
      {
        name: 'MIT 6.1200J - Discrete Math & Proofs',
        description: 'MIT course on predicates, sets, proofs, and discrete mathematics',
        links: [
          { type: 'site', href: '/blog/lecture-notes-zh/lec01/' }
        ]
      },
      {
        name: 'xv6-riscv Book Notes',
        description: 'Chapter-by-chapter notes on the xv6 operating system for RISC-V',
        links: [
          { type: 'site', href: '/blog/xv6-riscv-book/chapter1/' }
        ]
      }
    ]}
  />

  <h2 id='projects'>Projects</h2>
  <ProjectSection
    projects={[
      {
        name: 'Blog',
        description: 'This blog, built with Astro and the Pure theme, styled with newsprint typography',
        links: [
          { type: 'github', href: 'https://github.com/114514kirito' }
        ]
      }
    ]}
  />

  <div class='mt-8 text-center text-sm opacity-50'>
    <p>Built with <a href='https://github.com/cworld1/astro-theme-pure' target='_blank'>Astro Theme Pure</a></p>
  </div>
</PageLayout>
